# ProfSearch auto-loads `.env` from the repo root.
# In the prompt-first flow, the most common values to set are:
# - PROFSEARCH_CONFIG_FILE=.profsearch/config.toml
# - PROFSEARCH_DB_PATH=/absolute/path/to/.profsearch/data/profsearch.db
# - PROFSEARCH_OPENALEX_API_KEY=... or PROFSEARCH_OPENALEX_API_KEYS=...

PROFSEARCH_CONFIG_FILE=
PROFSEARCH_PROFILE=default
PROFSEARCH_CONFIG_DIR=
PROFSEARCH_DATA_DIR=
PROFSEARCH_CACHE_DIR=
PROFSEARCH_RUNS_DIR=
PROFSEARCH_DB_PATH=
PROFSEARCH_OPENALEX_EMAIL=
PROFSEARCH_OPENALEX_API_KEY=
PROFSEARCH_OPENALEX_API_KEYS=
PROFSEARCH_HTTP_TIMEOUT=20
PROFSEARCH_REQUEST_DELAY_SECONDS=0.35
PROFSEARCH_CONCURRENT_REQUESTS=4
PROFSEARCH_PUBLICATION_START_YEAR=2021
PROFSEARCH_MATCH_THRESHOLD=0.82
PROFSEARCH_AMBIGUITY_MARGIN=0.05
PROFSEARCH_SEARCH_RESULT_LIMIT=10
PROFSEARCH_SEARCH_WORK_LIMIT=5
PROFSEARCH_EMBEDDING_BACKEND=sentence_transformers
PROFSEARCH_EMBEDDING_MODEL=allenai/specter2_base
PROFSEARCH_SQLITE_VEC_EXTENSION=
